# ============================================================
# AlphaIQ — environment configuration
# Copy this file to `.env` and fill in real values.
# ============================================================

# ---- App ----
APP_ENV=dev
LOG_LEVEL=INFO
# Comma-separated origins; the Vite dev server runs on 5173.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ---- LLM provider ----
# Choose one: openai | anthropic | mock
# `mock` runs the whole pipeline offline (no API keys needed).
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-5

# ---- Vector store ----
# Choose one: chroma | pinecone
VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=alphaiq

# Only used when VECTOR_BACKEND=pinecone
PINECONE_API_KEY=
PINECONE_INDEX=alphaiq
PINECONE_ENVIRONMENT=us-east-1

# ---- Ingestion ----
CHUNK_SIZE_TOKENS=700
CHUNK_OVERLAP_TOKENS=100
MAX_UPLOAD_MB=50

# ---- Retrieval ----
RETRIEVAL_TOP_K=6
RETRIEVAL_MIN_SCORE=0.15
